# Heroes Live Forever — environment variables
# Copy this file to .env and fill in real values for local dev.

# Server port (defaults to 3001 if unset)
PORT=3001

# Anthropic API key — used by src/services/paletteGenerator.js
# Get one at https://console.anthropic.com/
# If unset, the palette generator returns a sensible fallback palette
# so local dev works without keys.
ANTHROPIC_API_KEY=
